{
  "ConnectionStrings": {
    "JobStore": "Data Source=jobscheduler.db"
  },
  "JobScheduler": {
    "Workers": {
      "WorkerCount": 1,
      "PollIntervalSeconds": 1,
      "SimulatedWorkDurationSeconds": 2,
      "LeaseSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
