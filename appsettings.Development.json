{
  "DetailedErrors": true,
  "ConnectionStrings": {
    "JobStore": "Data Source=jobscheduler-dev.db"
  },
  "JobScheduler": {
    "Workers": {
      "WorkerCount": 2,
      "PollIntervalSeconds": 1,
      "SimulatedWorkDurationSeconds": 2,
      "LeaseSeconds": 60
    },
    "DevelopmentActor": {
      "AllowRequestHeaders": false,
      "ActorId": "service-user",
      "TenantId": "tenant-alpha",
      "Permissions": [ "jobs.email.read", "jobs.global.read", "jobs.email.enqueue" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
