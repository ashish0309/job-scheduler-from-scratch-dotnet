@page
@using JobSchedulerPrototype.Jobs
@model IndexModel
@{
    ViewData["Title"] = "Jobs";
}

<section class="monitor-header">
    <div>
        <h1>Jobs</h1>
        <p>Current job activity.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/api/jobs">API</a>
</section>

<section class="status-summary" aria-label="Job status summary">
    <div class="status-tile">
        <span>Queued</span>
        <strong>@Model.QueuedCount</strong>
    </div>
    <div class="status-tile">
        <span>Running</span>
        <strong>@Model.RunningCount</strong>
    </div>
    <div class="status-tile">
        <span>Completed</span>
        <strong>@Model.CompletedCount</strong>
    </div>
    <div class="status-tile">
        <span>Failed</span>
        <strong>@Model.FailedCount</strong>
    </div>
</section>

@if (Model.Jobs.Count == 0)
{
    <section class="empty-state">
        <h2>No jobs yet</h2>
        <p>Enqueue jobs with <code>requests/jobs.http</code>, then refresh this page.</p>
    </section>
}
else
{
    <div class="table-responsive">
        <table class="table job-table align-middle">
            <thead>
                <tr>
                    <th scope="col">Job</th>
                    <th scope="col">Tenant</th>
                    <th scope="col">Created by</th>
                    <th scope="col">Status</th>
                    <th scope="col">Attempts</th>
                    <th scope="col">Scheduled</th>
                    <th scope="col">Enqueued</th>
                    <th scope="col">Finished</th>
                    <th scope="col">Failure</th>
                    <th scope="col">API</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in Model.Jobs)
                {
                    <tr>
                        <td>
                            <div class="job-type">@job.Type</div>
                            <a class="job-id" asp-page="/Jobs/Details" asp-route-id="@job.Id">@job.Id</a>
                        </td>
                        <td class="job-meta">@job.TenantId</td>
                        <td class="job-meta">@job.CreatedByActorId</td>
                        <td>
                            <span class="status-badge status-@job.Status.ToString().ToLowerInvariant()">@job.Status</span>
                        </td>
                        <td>@job.AttemptCount / @job.MaxAttempts</td>
                        <td>@FormatTimestamp(job.ScheduledAt)</td>
                        <td>@job.EnqueuedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz")</td>
                        <td>@FormatTimestamp(job.CompletedAt ?? job.FailedAt)</td>
                        <td>
                            @if (job.Status == JobStatus.Failed)
                            {
                                <span class="failure-summary">@job.FailureReason</span>
                            }
                            else
                            {
                                <span class="text-muted">None</span>
                            }
                        </td>
                        <td><a href="@job.StatusUrl">@job.StatusUrl</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "Not yet";
    }

}
