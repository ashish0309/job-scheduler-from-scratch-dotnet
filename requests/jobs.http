@baseUrl = http://localhost:5088
@actorId = service-user
@tenantId = tenant-alpha
@permissions = jobs.email.read,jobs.global.read,jobs.email.enqueue

### Enqueue a supported job
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_123",
    "email": "person@example.com"
  }
}

### Enqueue a billing receipt job sample
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_456",
    "email": "billing@example.com",
    "template": "receipt-ready"
  }
}

### Enqueue a trial reminder job sample
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_789",
    "email": "trial@example.com",
    "template": "trial-ending"
  }
}

### Enqueue an onboarding nudge job sample
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_abc",
    "email": "onboarding@example.com",
    "template": "finish-profile"
  }
}

### Enqueue a job that will fail during execution and auto-retry
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_fail",
    "email": "failure@example.com",
    "shouldFail": true
  }
}

### Enqueue a delayed job
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "delaySeconds": 30,
  "payload": {
    "userId": "user_scheduled",
    "email": "scheduled@example.com"
  }
}

### List jobs
GET {{baseUrl}}/api/jobs

### Get a job by id
GET {{baseUrl}}/api/jobs/00000000-0000-0000-0000-000000000000

### Reject unsupported job type
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "not-a-real-job",
  "payload": {}
}

### Reject missing payload
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email"
}

### Reject missing email in payload
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{actorId}}
X-Tenant-Id: {{tenantId}}
X-Permissions: {{permissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "user_123"
  }
}

### ------------------------------------------------------------
### Manual Auth + Visibility Test Matrix
### ------------------------------------------------------------
### Notes:
### 1) Run the setup requests first and copy IDs into @ownerAJobId, @ownerBJobId, @tenantBJobId.
### 2) Expected outcomes are listed before each request.
### 3) Current model: read requires jobs.email.read. Within a tenant:
###    - owner can read own jobs
###    - jobs.email.manage can read all jobs in that tenant
###    - cross-tenant remains hidden

@ownerATenant = tenant-alpha
@ownerAActor = owner-alpha
@ownerBActor = owner-beta
@tenantB = tenant-beta
@tenantBActor = owner-gamma
@managerActor = manager-alpha

@enqueueOnlyPermissions = jobs.email.enqueue
@readOnlyPermissions = jobs.email.read
@readManagePermissions = jobs.email.read,jobs.email.manage

@ownerAJobId = 00000000-0000-0000-0000-000000000000
@ownerBJobId = 00000000-0000-0000-0000-000000000000
@tenantBJobId = 00000000-0000-0000-0000-000000000000

### Setup 1 (Expected: 202 Accepted)
### Creates a tenant-alpha job owned by owner-alpha.
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{enqueueOnlyPermissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "ownerA_seed",
    "email": "ownerA_seed@example.com"
  }
}

### Setup 2 (Expected: 202 Accepted)
### Creates a tenant-alpha job owned by owner-beta.
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{ownerBActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{enqueueOnlyPermissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "ownerB_seed",
    "email": "ownerB_seed@example.com"
  }
}

### Setup 3 (Expected: 202 Accepted)
### Creates a tenant-beta job owned by owner-gamma.
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{tenantBActor}}
X-Tenant-Id: {{tenantB}}
X-Permissions: {{enqueueOnlyPermissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "tenantB_seed",
    "email": "tenantB_seed@example.com"
  }
}

### Case A (Expected: 200 OK with only owner-alpha jobs)
GET {{baseUrl}}/api/jobs
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readOnlyPermissions}}

### Case B (Expected: 404 Not Found)
### owner-alpha attempts to read owner-beta's job in the same tenant.
GET {{baseUrl}}/api/jobs/{{ownerBJobId}}
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readOnlyPermissions}}

### Case C (Expected: 200 OK)
### owner-alpha reads their own job.
GET {{baseUrl}}/api/jobs/{{ownerAJobId}}
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readOnlyPermissions}}

### Case D (Expected: 200 OK with tenant-alpha jobs from both owners)
GET {{baseUrl}}/api/jobs
X-Actor-Id: {{managerActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readManagePermissions}}

### Case E (Expected: 404 Not Found)
### manager in tenant-alpha attempts cross-tenant read of tenant-beta job.
GET {{baseUrl}}/api/jobs/{{tenantBJobId}}
X-Actor-Id: {{managerActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readManagePermissions}}

### Case F (Expected: 403 Forbidden)
### Missing jobs.email.read permission.
GET {{baseUrl}}/api/jobs
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{enqueueOnlyPermissions}}

### Case G (Expected: 403 Forbidden)
### Missing jobs.email.enqueue permission.
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{ownerAActor}}
X-Tenant-Id: {{ownerATenant}}
X-Permissions: {{readOnlyPermissions}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "should_fail_enqueue",
    "email": "should_fail_enqueue@example.com"
  }
}

### ------------------------------------------------------------
### Mutation Rule Test Matrix (Acknowledge via UI)
### ------------------------------------------------------------
### Why UI:
### Acknowledge is currently a Razor Page POST handler (button on "/"), not a minimal API route.
### Use these requests to seed + verify records, and use the UI button for the mutation itself.
###
### Prereq for fast setup (optional):
### Set JobScheduler:DevelopmentActor:AllowRequestHeaders=true in appsettings.Development.json,
### then restart the app. This lets each request below impersonate a different user.
###
### If you prefer no per-request headers, set AllowRequestHeaders=false and switch
### ActorId/TenantId/Permissions in appsettings.Development.json between runs.

@mutTenantA = tenant-alpha
@mutTenantB = tenant-beta
@mutOwnerA = owner-alpha
@mutOwnerB = owner-beta
@mutOwnerC = owner-gamma
@mutManagerA = manager-alpha
@mutExecutor = worker-exec

@mutPermEnqueue = jobs.email.enqueue
@mutPermRead = jobs.email.read
@mutPermReadManage = jobs.email.read,jobs.email.manage
@mutPermExecuteOnly = jobs.execute

# @name mut_create_owner_a
### Seed A (Expected: 202 Accepted)
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{mutOwnerA}}
X-Tenant-Id: {{mutTenantA}}
X-Permissions: {{mutPermEnqueue}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "mutation_owner_a",
    "email": "mutation_owner_a@example.com"
  }
}

@mutOwnerAJobId = {{mut_create_owner_a.response.body.$.id}}

# @name mut_create_owner_b
### Seed B (Expected: 202 Accepted)
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{mutOwnerB}}
X-Tenant-Id: {{mutTenantA}}
X-Permissions: {{mutPermEnqueue}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "mutation_owner_b",
    "email": "mutation_owner_b@example.com"
  }
}

@mutOwnerBJobId = {{mut_create_owner_b.response.body.$.id}}

# @name mut_create_owner_c
### Seed C (Expected: 202 Accepted)
POST {{baseUrl}}/api/jobs
X-Actor-Id: {{mutOwnerC}}
X-Tenant-Id: {{mutTenantB}}
X-Permissions: {{mutPermEnqueue}}
Content-Type: application/json

{
  "type": "send-welcome-email",
  "payload": {
    "userId": "mutation_owner_c",
    "email": "mutation_owner_c@example.com"
  }
}

@mutOwnerCJobId = {{mut_create_owner_c.response.body.$.id}}

### UI Scenario 1: Owner can read own job but cannot acknowledge (Expected: blocked by action-layer auth)
### Actor config:
###   ActorId=owner-alpha, TenantId=tenant-alpha, Permissions=[jobs.email.read]
### Action:
###   Open "/" and click Acknowledge on job {{mutOwnerAJobId}}
### Expected:
###   Job row is visible (read works)
###   Status message: "Actor is not authorized to acknowledge jobs."
###   AcknowledgedBy remains unchanged

### UI Scenario 2: Peer owner cannot acknowledge (Expected: blocked)
### Actor config:
###   ActorId=owner-beta, TenantId=tenant-alpha, Permissions=[jobs.email.read]
### Action:
###   Open "/" and click Acknowledge on any visible job
### Expected:
###   Status message: "Actor is not authorized to acknowledge jobs."
###   AcknowledgedBy should remain unchanged

### UI Scenario 3: Tenant manager can acknowledge any job in same tenant (Expected: success)
### Actor config:
###   ActorId=manager-alpha, TenantId=tenant-alpha, Permissions=[jobs.email.read,jobs.email.manage]
### Action:
###   Open "/" and click Acknowledge on job {{mutOwnerBJobId}}
### Expected:
###   Status message: "Acknowledged job ..."
###   Row shows Acknowledged by manager-alpha

### UI Scenario 4: Execute-only actor cannot acknowledge (Expected: blocked by action-layer auth)
### Actor config:
###   ActorId=worker-exec, TenantId=tenant-alpha, Permissions=[jobs.execute]
### Action:
###   Open "/" and click Acknowledge on any tenant-alpha job
### Expected:
###   Status message: "Actor is not authorized to acknowledge jobs."

### UI Scenario 5: Tenant manager cannot cross tenant by default (Expected: blocked)
### Actor config:
###   ActorId=manager-alpha, TenantId=tenant-alpha, Permissions=[jobs.email.read,jobs.email.manage]
### Action:
###   Open "/" and try to acknowledge job {{mutOwnerCJobId}} from tenant-beta
### Expected:
###   The job is not listed OR acknowledge attempt fails with "outside your scope"

### Verify Owner A job current state (run as manager in tenant-alpha, expected 200)
GET {{baseUrl}}/api/jobs/{{mutOwnerAJobId}}
X-Actor-Id: {{mutManagerA}}
X-Tenant-Id: {{mutTenantA}}
X-Permissions: {{mutPermReadManage}}

### Verify Owner B job current state (run as manager in tenant-alpha, expected 200)
GET {{baseUrl}}/api/jobs/{{mutOwnerBJobId}}
X-Actor-Id: {{mutManagerA}}
X-Tenant-Id: {{mutTenantA}}
X-Permissions: {{mutPermReadManage}}

### Verify cross-tenant job visibility from tenant-alpha manager (expected 404)
GET {{baseUrl}}/api/jobs/{{mutOwnerCJobId}}
X-Actor-Id: {{mutManagerA}}
X-Tenant-Id: {{mutTenantA}}
X-Permissions: {{mutPermReadManage}}
