{
  "Urls": "http://localhost:5088",
  "ConnectionStrings": {
    "JobStore": "Data Source=jobscheduler.db"
  },
  "JobScheduler": {
    "Workers": {
      "WorkerCount": 1,
      "PollIntervalSeconds": 1,
      "SimulatedWorkDurationSeconds": 2,
      "LeaseSeconds": 60
    },
    "DevelopmentActor": {
      "AllowRequestHeaders": true,
      "ActorId": "dev-user",
      "TenantId": "dev-tenant",
      "Permissions": [ "jobs.*" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
